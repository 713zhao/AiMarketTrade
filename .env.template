# Deerflow + OpenBB Integration - Environment Configuration Template
# Copy this file to .env and fill in your actual API keys

# ============================================================================
# OPENBB DATA PROVIDER API KEYS
# ============================================================================
# Required for enhanced data access (free tier keys work for basic usage)

# Financial Modeling Prep (FMP) - Recommended for fundamentals
FMP_API_KEY=your_fmp_api_key_here

# Polygon.io - Recommended for real-time data
POLYGON_API_KEY=your_polygon_api_key_here

# Alpha Vantage - Alternative for stocks/forex
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# EOD Historical Data
EODHD_API_KEY=your_eodhd_api_key_here

# Benzinga - News data
BENZINGA_API_KEY=your_benzinga_api_key_here

# ============================================================================
# LLM PROVIDER API KEYS
# ============================================================================

# OpenAI (for GPT-4/3.5 models)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# Default model for analyst agents (OPENAI: gpt-4, gpt-3.5-turbo; ANTHROPIC: claude-3-opus, claude-3-sonnet)
DEFAULT_LLM_MODEL=gpt-4

# Redis configuration (for caching)
REDIS_URL=redis://localhost:6379/0

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================

# Default tickers to analyze (comma-separated)
DEFAULT_TICKERS=AAPL,MSFT,GOOGL,AMZN,META

# Analysis time horizon (SHORT, MEDIUM, LONG)
TIME_HORIZON=MEDIUM

# Risk tolerance (CONSERVATIVE, MODERATE, AGGRESSIVE)
RISK_TOLERANCE=MODERATE

# Maximum position size (% of portfolio)
MAX_POSITION_SIZE=5.0

# ============================================================================
# NOTE:
# After filling in your API keys, save this file as .env in the project root
# The application will automatically load environment variables from .env
# ============================================================================
